GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
# Render: paste Internal/External URL from Render Dashboard
# Local: postgresql://localhost:5432/smart_onboarding
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Set to true when using Render (or any remote PostgreSQL)
DATABASE_SSL=true
PORT=3001
